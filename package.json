{
  "name": "devscope",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:clean": "node scripts/kill-ports.js && turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "kill-ports": "node scripts/kill-ports.js",
    "db:generate": "pnpm --filter @devscope/db db:generate",
    "db:migrate": "pnpm --filter @devscope/db db:migrate",
    "db:push": "pnpm --filter @devscope/db db:push",
    "db:studio": "pnpm --filter @devscope/db studio",
    "build:check": "echo '验证 API 镜像构建...' && docker build -f apps/api/Dockerfile . -t devscope/api:check --quiet && echo 'API 镜像构建成功' && echo '验证 Web 镜像构建...' && docker build -f apps/web/Dockerfile . -t devscope/web:check --quiet && echo 'Web 镜像构建成功' && echo '所有镜像构建验证通过'"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "dotenv": "^16.6.1"
  }
}
