{
  "name": "@devscope/ai",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs",
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./langtum": {
      "import": "./dist/langtum.mjs",
      "require": "./dist/langtum.mjs",
      "default": "./dist/langtum.mjs",
      "types": "./dist/langtum.d.mts"
    },
    "./agent": {
      "import": "./dist/agent.mjs",
      "require": "./dist/agent.mjs",
      "default": "./dist/agent.mjs",
      "types": "./dist/agent.d.mts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@devscope/shared": "workspace:*",
    "openai": "^4.77.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/ui": "^3.2.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
