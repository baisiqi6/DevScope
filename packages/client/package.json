    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@devscope/shared": "workspace:*",
    "@trpc/client": "11.13.4",
    "@trpc/server": "11.13.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
