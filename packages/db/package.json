{
  "name": "@devscope/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@devscope/ai": "workspace:*",
    "@devscope/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "octokit": "^5.0.5",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "uuid": "^11.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^3.2.4",
    "drizzle-kit": "^0.30.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
