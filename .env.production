# DevScope 生产环境变量模板。
#
# 在服务器上复制为 `.env`，并在该文件中替换全部占位值。
# 禁止把真实生产凭据提交到本文件。

POSTGRES_PASSWORD=change-me-before-deploy
DATABASE_URL=postgresql://postgres:change-me-before-deploy@postgres:5432/devscope

GITHUB_TOKEN=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

SILICONFLOW_API_KEY=
BGE_API_URL=https://api.siliconflow.cn/v1
BGE_MODEL_NAME=BAAI/bge-m3

LANGTUM_API_KEY=
LANGTUM_BASE_URL=https://demo.langcore.cn

PORT=3100
ENABLE_SCHEDULER=true
