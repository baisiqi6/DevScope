# ==============================================================================
# DevScope 生产环境变量配置
# ==============================================================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.production .env
#
# ⚠️ 注意: .env 文件包含敏感信息，请勿提交到 Git

# ============================================================================
# Database (必填)
# ============================================================================
# PostgreSQL 强密码（至少 16 位，包含大小写字母、数字和特殊字符）
POSTGRES_PASSWORD=请替换为强密码

# 数据库连接字符串（密码与上面保持一致）
DATABASE_URL=postgresql://postgres:请替换为强密码@postgres:5432/devscope

# ============================================================================
# GitHub API (推荐)
# ============================================================================
# 获取方式: https://github.com/settings/tokens
# 不配置则 GitHub 数据采集会受到严格限流
GITHUB_TOKEN=

# ============================================================================
# AI Services (至少配置一个)
# ============================================================================

# DeepSeek API (推荐 - 国内可用，成本低)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Anthropic Claude API (可选)
# ANTHROPIC_API_KEY=

# ============================================================================
# Embedding 向量化服务 (推荐)
# ============================================================================
# 硅基流动 BGE-M3 云服务
SILICONFLOW_API_KEY=
BGE_API_URL=https://api.siliconflow.cn/v1
BGE_MODEL_NAME=BAAI/bge-m3

# ============================================================================
# Langcore 工作流平台 (可选)
# ============================================================================
# LANGTUM_API_KEY=
# LANGTUM_BASE_URL=https://demo.langcore.cn

# ============================================================================
# Server
# ============================================================================
# API 端口（Docker 内部使用，一般不需要修改）
PORT=3001

# 调度器开关
ENABLE_SCHEDULER=true
