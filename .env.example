# ==============================================================================
# DevScope 环境变量配置示例
# ==============================================================================
# 复制此文件为 .env 并填入实际值

# ============================================================================
# Database
# ============================================================================
# PostgreSQL 数据库连接字符串
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devscope

# ============================================================================
# AI Services
# ============================================================================

# Anthropic Claude API (用于 AI 分析，可选)
# 获取方式: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# DeepSeek API (用于 AI 分析，推荐 - 国内可用)
# 获取方式: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DeepSeek API 地址
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 模型名称: deepseek-chat (通用) 或 deepseek-coder (代码专用)
DEEPSEEK_MODEL=deepseek-chat

# 其他 OpenAI 兼容 API (可选)
# OPENAI_COMPATIBLE_API_KEY=your-api-key
# OPENAI_COMPATIBLE_BASE_URL=https://your-api-url

# GitHub API (用于采集仓库数据)
# 获取方式: https://github.com/settings/tokens
# 需要的权限: public_repo (读取公共仓库信息)
GITHUB_TOKEN=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

# BGE-M3 Embedding API (用于生成向量嵌入)
#
# 选项 1: 硅基流动云服务 (推荐，无需本地部署)
# 获取 API Key: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=your-siliconflow-api-key-here
# BGE-M3 云服务地址
BGE_API_URL=https://api.siliconflow.cn/v1
# BGE-M3 模型名称 (硅基流动)
BGE_MODEL_NAME=BAAI/bge-m3
#
# 选项 2: Xinference 本地服务
# 安装 Xinference:
#   pip install xinference
#
# 启动 BGE-M3 模型:
#   xinference launch --model-name bge-m3 --model-type embedding
#
# 本地地址:
#BGE_API_URL=http://localhost:9997/v1
#BGE_MODEL_NAME=bge-m3
#
# 其他可用的 BGE-M3 服务:
# - LocalAI: http://localhost:8080/v1
# - OpenAI 兼容接口: 根据实际配置

# OpenAI API (备选 embedding 服务，不推荐使用)
# OPENAI_API_KEY=your-openai-api-key-here

# ============================================================================
# Langtum/Langcore 工作流平台
# ============================================================================
# Langcore (原 Langtum) API Key
# 获取方式: 从 Langcore 平台获取
LANGTUM_API_KEY=sk-2yzl6ao4cm3i

# Langcore API 基础 URL（默认使用 demo 环境）
# 生产环境: https://langcore.cn
# 测试环境: https://demo.langcore.cn
LANGTUM_BASE_URL=https://demo.langcore.cn

# 默认工作流 ID（关注列表分析工作流）
#LANGTUM_DEFAULT_WORKFLOW_ID=cmmlmarrt010hgjpg0qi53204

# Webhook 密钥 (用于验证 webhook 请求，可选)
#LANGTUM_WEBHOOK_SECRET=your_webhook_secret

# ============================================================================
# Server
# ============================================================================
# API 服务器端口（默认 3100，避免与前端 3000 冲突）
PORT=3100
API_PORT=3100

# 前端 API 连接地址（客户端可访问）
NEXT_PUBLIC_API_URL=http://localhost:3100/trpc

# 前端开发服务器端口（由 Next.js 自动使用 3000）
# NEXT_PORT=3000  # Next.js 使用内置配置
